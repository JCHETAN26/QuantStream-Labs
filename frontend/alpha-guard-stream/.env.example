# URL of the QuantStream FastAPI backend the SSR proxy (/api/backend/*) forwards to.
# Local dev: the backend runs on http://localhost:8000 (default, may be omitted).
# Production (Vercel): set this to your hosted backend origin, e.g.
#   API_BASE=https://quantstream-api.onrender.com
#
# The proxy reads API_BASE first, then VITE_API_BASE, then falls back to localhost:8000.
# If the backend is unreachable, the UI transparently renders bundled mock fixtures.
API_BASE=http://localhost:8000
